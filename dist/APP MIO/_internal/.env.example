APP_ENV=development
DATABASE_URL=sqlite:///./app.db
STORAGE_DIR=storage/pdfs
MAX_UPLOAD_SIZE_MB=10
MAX_DOCS_PER_PERSON=50

# Admin panel credentials (change before deploying!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_SECRET_KEY=change-this-in-production-please

# SMTP email (for password recovery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@email.com

# Twilio SMS (optional — leave blank to disable SMS recovery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Backup automático (opcional)
# BACKUP_AUTO_ENABLED=true
# BACKUP_AUTO_PATH=C:\Users\cadey\OneDrive\Backups
# BACKUP_AUTO_INTERVAL_HOURS=24
